# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Jikka Japan - 環境変数設定ファイル
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# このファイルをコピーして .env.local という名前で保存し、
# 各値を実際の値に置き換えてください。
# .env.local は Git にコミットしないでください。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Formspree フォームID
# 設定方法：https://formspree.io でアカウント作成 → フォーム作成 → Form ID をコピー
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_FORMSPREE_RESERVATION_ID=YOUR_RESERVATION_FORM_ID
NEXT_PUBLIC_FORMSPREE_CONTACT_ID=YOUR_CONTACT_FORM_ID

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OTA 予約リンク（後で実際のURLに書き換え）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_AIRBNB_URL=https://www.airbnb.jp/YOUR_LISTING_ID
NEXT_PUBLIC_BOOKING_URL=https://www.booking.com/hotel/jp/YOUR_PROPERTY.html

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SNS リンク（後で実際のURLに書き換え）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/jikka_japan
NEXT_PUBLIC_FACEBOOK_URL=
